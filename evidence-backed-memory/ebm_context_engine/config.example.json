{
  "$schema": "./config.schema.json",
  "embedding": {
    "enabled": true,
    "baseUrl": "http://127.0.0.1:8085/v1",
    "model": "qwen3-embedding-4b",
    "dimension": 2560,
    "fallback": {
      "enabled": true,
      "baseUrl": "https://openrouter.ai/api/v1",
      "model": "qwen/qwen3-embedding-4b",
      "dimension": 2560,
      "apiKeyEnv": "EBM_EMBEDDING_API_KEY"
    }
  },
  "llm": {
    "enabled": true,
    "baseUrl": "https://api.openai.com/v1",
    "model": "gpt-4o-mini",
    "apiKeyEnv": "EBM_LLM_API_KEY",
    "temperature": 0.6,
    "max_tokens": 32768,
    "top_p": 0.95,
    "stream": true,
    "thinking": {
      "type": "disabled"
    }
  },
  "memllm": {
    "enabled": true,
    "baseUrl": "https://api.ikuncode.cc/v1",
    "model": "gpt-4o-mini",
    "apiKey": "sk-xx",
    "temperature": 0.6,
    "max_tokens": 32768,
    "top_p": 0.95,
    "stream": true,
    "thinking": {
      "type": "disabled"
    },
    "headers": {
      "User-Agent": "claude-cli/2.0.76 (external, cli)",
      "Authorization": "Bearer sk-xx"
    }
  },
  "tuning_ingest": {
    "dedupSimilarityThreshold": 0.95,
    "eventPromotionIndegreeThreshold": 3,
    "rebuildChangeThreshold": 7,
    "llmTruncationChars": 12000,
    "confidenceCeiling": 0.97
  },
  "tuning_qa": {
    "graphItemsLimit": 5,
    "ledgerItemsLimit": 5,
    "recallContentMaxTokens": 100,
    "episodicMaxTokens": 1200,
    "episodicHitsLimit": 3,
    "episodicMessageWindow": 2,
    "sessionSummaryBudgetRatio": 0.4,
    "sessionSummaryMaxTokens": 2000,
    "pinnedFactsLimit": 4,
    "generalizedRecallDiscount": 0.8,
    "graphRecallTopK": 20,
    "communityRecallTopK": 12,
    "ledgerRecallTopK": 12
  },
  "tuning_rrf": {
    "rrfK": 60
  },
  "tuning_ppr": {
    "pprDefaultIterations": 8,
    "pprDamping": 0.85
  },
  "tuning_graph": {
    "maxHops": 2,
    "entitySeedSimThreshold": 0.6,
    "generalizedVecSimThreshold": 0.4,
    "multiHopBonus": 1.5
  },
  "tuning_slowpath": {
    "slowPathConcurrency": 8,
    "slowPathJobTimeoutMs": 90000,
    "sdkTimeoutMs": 15000,
    "sdkMaxRetries": 1
  }
}
