{
  "name": "@ebm/openclaw-py-engine",
  "version": "0.3.0",
  "description": "EBM Python context engine plugin for OpenClaw — thin TS proxy to ebm_context_engine HTTP sidecar",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "3.2.4",
    "typescript": "^5.7.0",
    "vitest": "^3.2.0"
  },
  "peerDependencies": {
    "openclaw": "*"
  },
  "engines": {
    "node": ">=22.16.0"
  },
  "openclaw": {
    "extensions": [
      "./src/index.ts"
    ],
    "install": {
      "localPath": "extensions/ebm-context-engine"
    }
  }
}
